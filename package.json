{
  "name": "pi-agent-desktop",
  "version": "1.0.0",
  "description": "Unofficial desktop client for the open-source Pi coding agent",
  "main": "dist/main/main.js",
  "scripts": {
    "start": "concurrently \"npm run dev:renderer\" \"npm run dev:main\"",
    "dev:renderer": "webpack serve --config webpack.renderer.config.js --mode development",
    "predev:main": "npm run clean:dist",
    "dev:main": "cross-env NODE_ENV=development tsc -p tsconfig.main.json && cross-env NODE_ENV=development electron dist/main/main.js",
    "clean:dist": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "prebuild": "npm run clean:dist",
    "build": "webpack --config webpack.renderer.config.js --mode production && tsc -p tsconfig.main.json",
    "typecheck": "tsc --noEmit",
    "test": "npm run typecheck"
  },
  "keywords": [
    "electron",
    "react",
    "typescript",
    "ide",
    "vscode"
  ],
  "author": "",
  "license": "MIT",
  "sideEffects": [
    "*.css"
  ],
  "dependencies": {
    "clsx": "^2.1.1",
    "lucide-react": "^1.16.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "remark-gfm": "^4.0.1",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/react-syntax-highlighter": "^15.5.13",
    "autoprefixer": "^10.5.0",
    "concurrently": "^8.2.0",
    "cross-env": "^7.0.3",
    "css-loader": "^6.8.0",
    "electron": "^28.0.0",
    "html-webpack-plugin": "^5.5.0",
    "postcss": "^8.5.15",
    "postcss-loader": "^8.2.1",
    "style-loader": "^3.3.0",
    "tailwindcss": "^4.3.0",
    "ts-loader": "^9.5.0",
    "typescript": "^5.3.0",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.0",
    "webpack-dev-server": "^4.15.0"
  }
}
